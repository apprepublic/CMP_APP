# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API URL (keep for auth endpoints that remain on Express backend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# NOWPayments Configuration
# TODO(prod): Add your NOWPayments API credentials to enable crypto top-ups
NEXT_PUBLIC_NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret

# Feature Flags
# Set to 'true' to enable payment features (requires valid API keys above)
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# Payout Provider Keys (for withdrawal processing)
# TODO(prod): Add your payout provider credentials (e.g., Paystack, Flutterwave)
PAYOUT_PROVIDER_API_KEY=your-payout-api-key
PAYOUT_PROVIDER_SECRET=your-payout-secret