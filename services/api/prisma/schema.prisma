// CMPapp Prisma Schema
// Based on Document 3: Data Schema & State Map

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// ENUMS
// ===========================================

enum UserRole {
  USER
  ARTIST
  BUSINESS
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum CoinTransactionType {
  TASK_EARN
  READ_ARTICLE
  WATCH_AD
  SHARE_TASK
  SURVEY
  APP_DOWNLOAD
  VOTE
  MUSIC_STREAM
  MUSIC_DOWNLOAD
  STREAK_BONUS
  REFERRAL_SIGNUP
  REFERRAL_EARN
  TOPUP
  WITHDRAWAL
  AIRTIME_PURCHASE
  DATA_PURCHASE
  ELECTRICITY_PURCHASE
  PRODUCT_LISTING_BOOST
  SONG_PROMOTION
  BUSINESS_FEATURED
  PREMIUM_TASK_UNLOCK
  STREAK_FREEZE
}

enum TaskType {
  READ_ARTICLE
  WATCH_VIDEO
  SHARE_SOCIAL
  COMPLETE_SURVEY
  APP_DOWNLOAD
  VOTE
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

enum WithdrawalMethod {
  BANK
  CRYPTO
}

enum Currency {
  NGN
  USDT
  BTC
}

enum ContestType {
  ARTIST
  BUSINESS
}

enum ContestEntryStatus {
  ACTIVE
  ELIMINATED
  WINNER
}

enum VtuServiceType {
  AIRTIME
  DATA
  ELECTRICITY
}

enum VtuStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

// ===========================================
// USER & AUTH
// ===========================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String    @unique
  passwordHash  String?
  displayName   String
  username      String    @unique
  role          UserRole  @default(USER)
  kycStatus     KycStatus @default(NONE)
  referredById  String?
  referralCode  String    @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  googleId      String?   @unique

  referredBy    User?     @relation("ReferralRelation", fields: [referredById], references: [id])
  referees      User[]    @relation("ReferralRelation")

  // Referral model relations
  referralsMade Referral[] @relation("ReferrerRelation")
  referralsReceived Referral[] @relation("RefereeRelation")

  wallet        Wallet?
  artistProfile ArtistProfile?
  businessProfile BusinessProfile?
  streakRecord  StreakRecord?
  kycRecord     KycRecord? @relation("KycUserRelation")
  kycReviews    KycRecord[] @relation("KycReviewerRelation")
  verification  UserVerification?

  tasks         TaskCompletion[]
  articles      Article[]
  votes         VoteCast[]
  orders        Order[]

  adminActions  AdminAction[]
  processedWithdrawals WithdrawalRequest[]

  notifications Notification[]

  postedTasks   UserPostedTask[]
  completedUserTasks UserTaskCompletion[]

  @@index([phone])
  @@index([email])
  @@index([referralCode])
}

model UserVerification {
  id              String   @id @default(cuid())
  userId          String   @unique
  emailOtp        String?
  emailOtpExpires DateTime?
  phoneOtp        String?
  phoneOtpExpires DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model KycRecord {
  id            String    @id @default(cuid())
  userId        String    @unique
  bvn           String?
  idNumber      String?
  idType        String?
  selfieUrl     String?
  idImageUrl    String?
  status        KycStatus @default(NONE)
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation("KycUserRelation", fields: [userId], references: [id])
  reviewer      User?     @relation("KycReviewerRelation", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
}

// ===========================================
// WALLET & TRANSACTIONS
// ===========================================

model Wallet {
  id            String    @id @default(cuid())
  userId        String    @unique
  coinBalance   BigInt    @default(0)
  pendingCoins  BigInt    @default(0)
  lifetimeEarned BigInt   @default(0)
  lifetimeSpent BigInt    @default(0)
  pinHash       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id])

  transactions  CoinTransaction[]
  withdrawals  WithdrawalRequest[]
}

model CoinTransaction {
  id            String            @id @default(cuid())
  walletId      String
  type          CoinTransactionType
  amount        BigInt
  balanceAfter  BigInt
  description   String
  metadata      Json?
  createdAt     DateTime          @default(now())

  wallet        Wallet            @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

model WithdrawalRequest {
  id              String            @id @default(cuid())
  walletId        String
  coinsAmount     BigInt
  fiatAmount      Float
  currency        Currency          @default(NGN)
  method          WithdrawalMethod @default(BANK)
  bankAccount     String?
  bankName        String?
  accountName     String?
  cryptoAddress   String?
  cryptoNetwork   String?
  status          WithdrawalStatus  @default(PENDING)
  rejectionReason String?
  processedById   String?
  processedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  wallet          Wallet            @relation(fields: [walletId], references: [id])
  processedBy    User?             @relation(fields: [processedById], references: [id])

  @@index([walletId])
  @@index([status])
  @@index([createdAt])
}

// ===========================================
// TASKS & EARNINGS
// ===========================================

model Task {
  id              String    @id @default(cuid())
  title           String
  description     String
  type            TaskType
  category        String    @default("ENGAGEMENT")
  coinReward      Int
  dailyLimit      Int       @default(1)
  requiresAdGate  Boolean   @default(true)
  linkedArticleId String?   @unique
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  linkedArticle   Article?  @relation(fields: [linkedArticleId], references: [id])
  completions     TaskCompletion[]

  @@index([type])
  @@index([isActive])
  @@index([category])
}

model TaskCompletion {
  id          String    @id @default(cuid())
  userId      String
  taskId      String?
  coinsEarned Int
  proofData   Json?
  adWatched   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  task        Task?     @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([taskId])
  @@index([createdAt])
}

model UserPostedTask {
  id                  String   @id @default(cuid())
  creatorId           String
  title               String
  description         String
  type                TaskType
  category            String   @default("USER_CREATED")
  participantThreshold Int     @default(100)
  totalBudget         Int
  coinPerParticipant  Int
  creationFee         Int      @default(500)
  status              UserTaskStatus
  currentParticipants Int      @default(0)
  isActive            Boolean  @default(false)
  expiresAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  creator           User           @relation(fields: [creatorId], references: [id])
  completions       UserTaskCompletion[]

  @@index([creatorId])
  @@index([status])
  @@index([isActive])
}

enum UserTaskStatus {
  PENDING
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

model UserTaskCompletion {
  id          String   @id @default(cuid())
  userId      String
  postedTaskId String
  completedAt DateTime @default(now())
  coinsEarned Int
  proofData   Json?

  user       User           @relation(fields: [userId], references: [id])
  postedTask UserPostedTask @relation(fields: [postedTaskId], references: [id])

  @@unique([userId, postedTaskId])
  @@index([userId])
  @@index([postedTaskId])
}

model StreakRecord {
  id              String    @id @default(cuid())
  userId          String    @unique
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastActiveDate DateTime?
  freezesOwned    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Article {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String    @db.Text
  excerpt         String?
  coverImageUrl   String?
  authorId        String
  category        String
  tags            String[]
  readTimeMinutes Int       @default(5)
  coinReward      Int       @default(50)
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  author          User      @relation(fields: [authorId], references: [id])
  linkedTask      Task?

  @@index([authorId])
  @@index([category])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([slug])
}

// ===========================================
// MUSIC / ARTIST
// ===========================================

model ArtistProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  stageName       String
  bio             String?   @db.Text
  genre           String?
  coverImageUrl   String?
  avatarUrl       String?
  followerCount   Int       @default(0)
  totalStreams    Int       @default(0)
  isVerified      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])
  songs           Song[]

  @@index([userId])
  @@index([stageName])
  @@index([isVerified])
}

model Song {
  id              String    @id @default(cuid())
  artistId        String
  title           String
  description     String?   @db.Text
  audioUrl        String
  coverUrl        String?
  durationSeconds Int       @default(0)
  genre           String?
  playCount       Int       @default(0)
  downloadCount   Int       @default(0)
  isPublished     Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  featuredAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  artist          ArtistProfile @relation(fields: [artistId], references: [id])
  streams         SongStream[]

  @@index([artistId])
  @@index([isPublished])
  @@index([isFeatured])
}

model SongStream {
  id            String    @id @default(cuid())
  songId        String
  userId        String?
  ipAddress     String?
  streamDuration Int      @default(0)
  createdAt     DateTime  @default(now())

  song          Song      @relation(fields: [songId], references: [id])

  @@index([songId])
  @@index([userId])
  @@index([createdAt])
}

// ===========================================
// MARKETPLACE / BUSINESS
// ===========================================

model BusinessProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  businessName    String
  description     String?   @db.Text
  category        String
  location        String?
  whatsappNumber  String?
  avatarUrl       String?
  coverImageUrl   String?
  isVerified      Boolean   @default(false)
  rating          Float     @default(0)
  totalSales      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])
  products        Product[]

  @@index([userId])
  @@index([businessName])
  @@index([category])
  @@index([isVerified])
}

model Product {
  id              String    @id @default(cuid())
  businessId      String
  name            String
  description     String?   @db.Text
  priceNaira      Float
  coinPrice       Int
  imageUrls       String[]
  category        String
  isFeatured      Boolean   @default(false)
  featuredUntil   DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business        BusinessProfile @relation(fields: [businessId], references: [id])
  orders          Order[]

  @@index([businessId])
  @@index([category])
  @@index([isFeatured])
  @@index([isActive])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  icon        String?
  parentId    String?
  createdAt   DateTime  @default(now())

  parent      ProductCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   ProductCategory[] @relation("CategoryHierarchy")

  @@index([slug])
  @@index([parentId])
}

model Order {
  id            String    @id @default(cuid())
  buyerId       String
  productId    String
  quantity      Int       @default(1)
  totalNaira    Float     @default(0)
  totalCoins    Int       @default(0)
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  buyer         User      @relation(fields: [buyerId], references: [id])
  product      Product   @relation(fields: [productId], references: [id])

  @@index([buyerId])
  @@index([productId])
  @@index([status])
}

// ===========================================
// REFERRALS
// ===========================================

model Referral {
  id              String    @id @default(cuid())
  referrerId      String
  refereeId       String    @unique
  level           Int       @default(1)
  commissionRate  Float     @default(0.20)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  referrer        User      @relation("ReferrerRelation", fields: [referrerId], references: [id])
  referee         User      @relation("RefereeRelation", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@index([refereeId])
  @@index([level])
}

// ===========================================
// VOTING / CONTESTS
// ===========================================

model Contest {
  id                String      @id @default(cuid())
  title             String
  description       String?     @db.Text
  type              ContestType
  coverImageUrl     String?
  startsAt          DateTime
  endsAt            DateTime
  isActive          Boolean     @default(true)
  prizeDescription  String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  entries           ContestEntry[]
  votes             VoteCast[]

  @@index([type])
  @@index([isActive])
  @@index([endsAt])
}

model ContestEntry {
  id                String            @id @default(cuid())
  contestId         String
  userId            String
  artistProfileId   String?
  businessProfileId String?
  description       String?           @db.Text
  imageUrl          String?
  voteCount         Int               @default(0)
  status            ContestEntryStatus @default(ACTIVE)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  contest           Contest           @relation(fields: [contestId], references: [id])
  votes             VoteCast[]

  @@index([contestId])
  @@index([userId])
  @@index([voteCount])
}

model VoteCast {
  id          String    @id @default(cuid())
  userId      String
  entryId     String
  contestId   String
  coinsEarned Int       @default(20)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  entry       ContestEntry @relation(fields: [entryId], references: [id])
  contest     Contest   @relation(fields: [contestId], references: [id])

  @@unique([userId, contestId])
  @@index([userId])
  @@index([entryId])
  @@index([contestId])
}

// ===========================================
// VTU SERVICES
// ===========================================

model VtuTransaction {
  id            String        @id @default(cuid())
  userId        String
  serviceType   VtuServiceType
  provider      String
  phoneNumber   String
  amount        Float
  coinsUsed     Int
  networkCode   String?
  bundleCode    String?
  meterNumber   String?
  status        VtuStatus     @default(PENDING)
  externalRef   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([externalRef])
}

// ===========================================
// NOTIFICATIONS
// ===========================================

model Notification {
  id          String           @id @default(cuid())
  userId      String
  title       String
  message     String
  type        NotificationType @default(INFO)
  isRead      Boolean          @default(false)
  metadata    Json?
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ===========================================
// ADMIN
// ===========================================

model AdminAction {
  id          String    @id @default(cuid())
  adminId     String
  actionType  String
  targetType  String
  targetId    String
  details     Json?
  createdAt   DateTime  @default(now())

  admin       User      @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}